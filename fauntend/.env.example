# ═════════════════════════════════════════════════════════════════════════════
# Frontend Environment Configuration - copy to .env.local for development
# ═════════════════════════════════════════════════════════════════════════════

# ─── Public URLs (visible to browser) ────────────────────────────────────────
# These are sent to the client and used for media streaming, proxy URLs
NEXT_PUBLIC_BASE_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:8081

# ─── Backend URL (server-side only - drives Next.js rewrites) ────────────────
# NOT visible to browser. Used by Next.js to rewrite API calls to backend
# Enables auto-connection without CORS issues
BACKEND_URL=http://localhost:8081

# ─── BFF Authentication (Backend-for-Frontend) ───────────────────────────────
# CRITICAL: Must match backend WEB_INTERNAL_SHARED_SECRET exactly
# Used to sign requests between frontend and backend
# Development: Use insecure value for testing
# Production: Match the secure value generated in Render
WEB_INTERNAL_SHARED_SECRET=dev-secret-key-change-in-production

# ─── Supabase Authentication (required for user auth) ────────────────────────
# Get from: supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# ─── Push Notifications (optional) ───────────────────────────────────────────
# For web push notifications (PWA feature):
# Generate from: vapidkey.com
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-public-key

# ─── Logging (optional) ──────────────────────────────────────────────────────
# LOG_LEVEL=info

# ═════════════════════════════════════════════════════════════════════════════
# PRODUCTION ENVIRONMENT (Vercel Dashboard)
# ═════════════════════════════════════════════════════════════════════════════

# NEXT_PUBLIC_BASE_URL=https://your-project.vercel.app
# NEXT_PUBLIC_API_URL=https://downloader-api-xxxxx.onrender.com
# BACKEND_URL=https://downloader-api-xxxxx.onrender.com
# WEB_INTERNAL_SHARED_SECRET=same-as-render-value
# NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# ═════════════════════════════════════════════════════════════════════════════
# IMPORTANT NOTES
# ═════════════════════════════════════════════════════════════════════════════
# - NEVER commit .env.local to git (add to .gitignore)
# - NEXT_PUBLIC_* variables are embedded in bundles (public-safe only)
# - Other variables are removed from bundle (safe for secrets)
# - WEB_INTERNAL_SHARED_SECRET signs requests for backend authentication
# - Copy this file to .env.local in development
# - Use Vercel Dashboard for production environment variables
# ═════════════════════════════════════════════════════════════════════════════
