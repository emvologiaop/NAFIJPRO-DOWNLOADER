{
  "$schema": "https://openapi.vercel.com/vercel.json",
  "framework": "nextjs",
  "rootDirectory": "fauntend",
  "buildCommand": "cd fauntend && npm run build",
  "installCommand": "cd fauntend && npm install",
  "nodeVersion": "20",
  "outputDirectory": "fauntend/.next",
  "regions": ["iad1"],
  "functions": {
    "fauntend/src/app/api/**": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "env": [
    {
      "key": "NEXT_PUBLIC_API_URL",
      "value": "https://nafijthepro-downloader.onrender.com",
      "type": "system"
    },
    {
      "key": "BACKEND_URL",
      "value": "https://nafijthepro-downloader.onrender.com",
      "type": "system"
    },
    {
      "key": "NEXT_PUBLIC_BASE_URL",
      "value": "https://downloader.nafij.me",
      "type": "system"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/((?!_next/static|_next/image|.*\\.(?:png|jpg|jpeg|gif|webp|ico|svg|woff|woff2|css|js)).*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    }
  ]
}
