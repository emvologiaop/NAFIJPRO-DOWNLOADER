# ═════════════════════════════════════════════════════════════════════════════
# NAFIJPRO-DOWNLOADER Environment Configuration
# ═════════════════════════════════════════════════════════════════════════════
# DEVELOPMENT: Copy to backend/.env and fauntend/.env.local
# PRODUCTION: Set variables in Render dashboard (backend) and Vercel dashboard (frontend)
# ═════════════════════════════════════════════════════════════════════════════

# ═════════════════════════════════════════════════════════════════════════════
# BACKEND CONFIGURATION (backend/.env or Render environment)
# ═════════════════════════════════════════════════════════════════════════════

# Server Configuration
PORT=8081
ENV=development
PUBLIC_BASE_URL=http://localhost:8081

# Security: BFF Shared Secret
# CRITICAL: Must match between frontend and backend
# Generate: openssl rand -base64 24
# Production: Use Render's generateValue: true in render.yaml
WEB_INTERNAL_SHARED_SECRET=dev-secret-key-change-in-production

# CORS: Frontend origin(s)
# Development: http://localhost:3001
# Production: https://your-vercel-app.vercel.app
ALLOWED_ORIGINS=http://localhost:3001

# Media Extraction & Processing
MERGE_ENABLED=true
UPSTREAM_TIMEOUT_MS=10000
MAX_DOWNLOAD_SIZE_MB=1024
EXTRACTION_MAX_RETRIES=3

# Rate Limiting (format: "limit/duration")
GLOBAL_RATE_LIMIT_WINDOW=60/1m

# Result Caching
CACHE_EXTRACTION_TTL=5m
CACHE_PROXY_HEAD_TTL=45s

# Stats Persistence (optional)
STATS_PERSIST_ENABLED=false
STATS_PERSIST_FILE_PATH=./data/public_stats.json
STATS_PERSIST_FLUSH_INTERVAL_MS=5000

# ═════════════════════════════════════════════════════════════════════════════
# FRONTEND CONFIGURATION (fauntend/.env.local or Vercel environment)
# ═════════════════════════════════════════════════════════════════════════════

# Public URLs (visible to browser)
NEXT_PUBLIC_BASE_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:8081

# Backend URL (server-side only - drives Next.js rewrites)
# Not visible to browser, used for API proxying through Vercel
BACKEND_URL=http://localhost:8081

# Security: BFF Shared Secret (must match backend)
WEB_INTERNAL_SHARED_SECRET=dev-secret-key-change-in-production

# Supabase Authentication (optional but recommended)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Push Notifications (optional)
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-public-key

# ═════════════════════════════════════════════════════════════════════════════
# PRODUCTION DEPLOYMENT EXAMPLES
# ═════════════════════════════════════════════════════════════════════════════

# Backend on Render:
# ─────────────────────────────────────────────────────────────────────────────
# PORT=10000
# ENV=production
# PUBLIC_BASE_URL=https://downloader-api-xxxxx.onrender.com
# WEB_INTERNAL_SHARED_SECRET=your-generated-secret-32-chars
# ALLOWED_ORIGINS=https://your-project.vercel.app
# MERGE_ENABLED=true
# UPSTREAM_TIMEOUT_MS=15000
# MAX_DOWNLOAD_SIZE_MB=512
# GLOBAL_RATE_LIMIT_WINDOW=100/1m
# CACHE_EXTRACTION_TTL=5m
# CACHE_PROXY_HEAD_TTL=45s
# STATS_PERSIST_ENABLED=true

# Frontend on Vercel:
# ─────────────────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_BASE_URL=https://your-project.vercel.app
# NEXT_PUBLIC_API_URL=https://downloader-api-xxxxx.onrender.com
# BACKEND_URL=https://downloader-api-xxxxx.onrender.com
# WEB_INTERNAL_SHARED_SECRET=same-value-as-render
# NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# ═════════════════════════════════════════════════════════════════════════════
# NOTES
# ═════════════════════════════════════════════════════════════════════════════
# - Store sensitive values (.env, .env.local) locally - never commit to git
# - Use .gitignore to exclude .env files from version control
# - All files marked with * are required for both development and production
# - Files marked (optional) have sensible defaults if omitted
# ═════════════════════════════════════════════════════════════════════════════

