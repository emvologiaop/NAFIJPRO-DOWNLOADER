# ═════════════════════════════════════════════════════════════════════════════
# Backend Environment Configuration - copy to .env or .env.local for development
# ═════════════════════════════════════════════════════════════════════════════

# ─── Server Configuration ────────────────────────────────────────────────────
PORT=8081
ENV=development

# Public backend URL (used in responses & redirects)
PUBLIC_BASE_URL=http://localhost:8081

# ─── Security: BFF Shared Secret (CRITICAL) ─────────────────────────────────
# MUST be identical between frontend and backend
# Used to sign and validate requests via HMAC-SHA256
# Development: Use dummy value for testing
# Production: Generate strong random: openssl rand -base64 24
# Render: Set generateValue: true in render.yaml (auto-generated)
WEB_INTERNAL_SHARED_SECRET=dev-secret-key-change-in-production

# ─── CORS: Frontend origin(s) ────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Development: http://localhost:3001
# Production: https://your-frontend.vercel.app
ALLOWED_ORIGINS=http://localhost:3001

# ─── Media Extraction & Processing ──────────────────────────────────────────
# Enable FFmpeg merge functionality (video + audio → single file)
MERGE_ENABLED=true

# Timeout for external API calls (YouTube, Instagram, etc.)
# Value in milliseconds, default 10000 (10 seconds)
UPSTREAM_TIMEOUT_MS=10000

# Maximum size of files to proxy/download
# Value in MB, default 1024 (1GB), production usually 512
MAX_DOWNLOAD_SIZE_MB=1024

# Number of retries for transient errors
EXTRACTION_MAX_RETRIES=3

# ─── Rate Limiting ──────────────────────────────────────────────────────────
# Format: "limit/duration" (e.g., "60/1m" = 60 requests per minute)
# Development: 60/1m (generous for testing)
# Production: Usually higher (100/1m) to handle real usage
GLOBAL_RATE_LIMIT_WINDOW=60/1m

# ─── Caching (TTL = Time To Live) ───────────────────────────────────────────
# How long to cache extraction results
CACHE_EXTRACTION_TTL=5m

# How long to cache proxy metadata (HEAD requests)
CACHE_PROXY_HEAD_TTL=45s

# ─── Stats Persistence (optional) ───────────────────────────────────────────
# Enable file-based stats storage (counts, analytics)
STATS_PERSIST_ENABLED=false

# Where to store stats JSON file
STATS_PERSIST_FILE_PATH=./data/public_stats.json

# How often to flush stats to disk (milliseconds)
STATS_PERSIST_FLUSH_INTERVAL_MS=5000

# ═════════════════════════════════════════════════════════════════════════════
# PRODUCTION ENVIRONMENT (Render Dashboard)
# ═════════════════════════════════════════════════════════════════════════════

# PORT=10000
# ENV=production
# PUBLIC_BASE_URL=https://downloader-api-xxxxx.onrender.com
# WEB_INTERNAL_SHARED_SECRET=your-generated-strong-secret
# ALLOWED_ORIGINS=https://your-project.vercel.app
# MERGE_ENABLED=true
# UPSTREAM_TIMEOUT_MS=15000
# MAX_DOWNLOAD_SIZE_MB=512
# EXTRACTION_MAX_RETRIES=3
# GLOBAL_RATE_LIMIT_WINDOW=100/1m
# CACHE_EXTRACTION_TTL=5m
# CACHE_PROXY_HEAD_TTL=45s
# STATS_PERSIST_ENABLED=true

# ═════════════════════════════════════════════════════════════════════════════
# IMPORTANT NOTES
# ═════════════════════════════════════════════════════════════════════════════
# - NEVER commit .env to git (add to .gitignore)
# - Development: Copy to .env or .env.local (godotenv loads both)
# - Production: Use Render Dashboard environment variables
# - WEB_INTERNAL_SHARED_SECRET: Must match frontend value exactly
# - ALLOWED_ORIGINS: Update after Vercel deployment with correct URL
# - Health check endpoint: GET /health (required for Render health checks)
# - Dependencies: FFmpeg, yt-dlp (included in Docker image)
# ═════════════════════════════════════════════════════════════════════════════
